# Credenciales de la OAuth App de GitHub (Settings -> Developer settings -> OAuth Apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Credenciales OAuth de Google (Google Cloud Console -> APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cadena de conexion a Postgres (Vercel Postgres / Supabase / Neon la dan lista)
DATABASE_URL=

# Cualquier cadena larga y aleatoria — firma las cookies de sesion
SESSION_SECRET=

# Se agrega sola al crear un Blob Store desde la pestana Storage de Vercel
UPLOADS_READ_WRITE_TOKEN=
